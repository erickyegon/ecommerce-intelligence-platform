  "total_widgets": 44,
  "total_datasets": 33,
  "global_filters": {
    "filter_month": {
      "column_bindings": [
        "year_month",
        "acquisition_cohort"
      ],
      "bound_datasets": [
        "monthly_trends",
        "product_monthly",
        "refunds",
        "cohort_retention"
      ]
    },
    "filter_channel": {
      "column_bindings": [
        "marketing_channel"
      ],
      "bound_datasets": [
        "monthly_trends",
        "channel_cvr",
        "top_sessions"
      ]
    },
    "filter_device": {
      "column_bindings": [
        "device_type"
      ],
      "bound_datasets": [
        "monthly_trends",
        "channel_cvr",
        "billing_test",
        "funnel_unpivoted",
        "top_sessions"
      ]
    },
    "filter_product": {
      "column_bindings": [
        "primary_product_name"
      ],
      "bound_datasets": [
        "product_monthly"
      ]
    },
    "filter_customer_tier": {
      "column_bindings": [
        "customer_tier"
      ],
      "bound_datasets": [
        "customer_seg_summary"
      ]
    }
  },
  "data_sources": [
