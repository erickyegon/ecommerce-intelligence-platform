  "design_system": {
    "primary_color": "#1976D2",
    "background_color": "#F5F5F5",
    "layout": "modern_bi",
    "spacing": {
      "header_row": 0,
      "kpi_strip_row": 3,
      "main_analytics_row": 9,
      "details_row": 24
    }
  },
  "ml_models": {
    "conversion_prediction": {
      "type": "Logistic Regression",
      "auc_roc": 0.847,
      "features": [
        "marketing_channel",
        "device_type",
        "time_features"
      ],
      "target": "converted_label"
    },
    "customer_segmentation": {
      "type": "KMeans",
      "k": 4,
      "features": [
        "recency",
        "frequency",
        "monetary"
      ],
      "segments": [
        "VIP",
        "Premium",
        "Standard",
        "At-Risk"
      ]
    }
  },
